{
  "name": "@testplane/mcp",
  "version": "0.6.0",
  "description": "MCP server for Testplane tool",
  "main": "build/cli.js",
  "type": "module",
  "bin": {
    "testplane-mcp-server": "build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "prebuild": "npm --prefix ../tools run build",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "start": "node build/cli.js",
    "dev": "npm run build && node build/cli.js",
    "lint": "eslint .",
    "test-unit": "vitest run",
    "test": "npm run lint && npm run typecheck && npm run test-unit",
    "prepack": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.2",
    "@testplane/testing-library": "^1.0.5",
    "commander": "^13.1.0",
    "html-reporter": "^11.10.0-rc.1",
    "testplane": "^8.44.1-rc.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testplane/tools": "*",
    "esbuild": "^0.24.0",
    "serve-handler": "^6.1.6"
  }
}
