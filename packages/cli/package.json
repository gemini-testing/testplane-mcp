{
  "name": "@testplane/cli",
  "version": "0.0.1",
  "description": "Daemon-backed CLI for Testplane browser-automation tools",
  "main": "build/cli.js",
  "type": "module",
  "bin": {
    "testplane-cli": "build/cli.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "prebuild": "npm --prefix ../tools run build",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "start": "node build/cli.js",
    "dev": "npm run build && node build/cli.js",
    "lint": "eslint .",
    "test-unit": "vitest run",
    "test": "npm run lint && npm run typecheck && npm run test-unit",
    "prepack": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@testplane/testing-library": "^1.0.5",
    "@rrweb/replay": "^2.0.0-alpha.18",
    "commander": "^14.0.3",
    "debug": "^4.3.4",
    "html-reporter": "^11.9.4",
    "testplane": "^8.44.2-rc.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testplane/tools": "*",
    "@types/debug": "^4.1.12",
    "@types/serve-handler": "^6.1.4",
    "esbuild": "^0.24.0",
    "serve-handler": "^6.1.6"
  }
}
